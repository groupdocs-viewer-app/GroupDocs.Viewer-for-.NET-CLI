<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2012/06/nuspec.xsd">
  <metadata>
    <id>GroupDocs.Viewer-CLI</id>
    <version>$version$</version>
    <authors>GroupDocs</authors>
    <owners>GroupDocs</owners>
    <projectUrl>https://github.com/groupdocs-viewer-app/GroupDocs.Viewer-for-.NET-CLI</projectUrl>
    <icon>images\icon.png</icon>
    <readme>docs\README.md</readme>
    <license type="expression">MIT</license>
    <requireLicenseAcceptance>true</requireLicenseAcceptance>
    <description>View documents in the browser from your terminal. Run 'groupdocs-viewer' in any folder to start a local web server with an interactive document viewer. Supports 180+ file formats including PDF, Word, Excel, PowerPoint, images, CAD, archives, ebooks, and source code.</description>
    <summary>View documents in a browser - interactive GroupDocs.Viewer dotnet tool CLI.</summary>
    <copyright>Aspose Pty Ltd 2001-2026. All Rights Reserved.</copyright>
    <tags>
      Document-Viewer CLI Browser-Viewer Interactive-Viewer
      PDF Word Excel PowerPoint DOC DOCX XLS XLSX PPT PPTX TIFF PNG JPG
    </tags>
    <packageTypes>
      <packageType name="DotnetTool" />
    </packageTypes>
  </metadata>
  <files>
    <file src="Resources\icon.png" target="images\" />
    <file src="..\..\README.md" target="docs\" />
    <file src="obj\DotnetToolSettings.xml" target="tools\net8.0\any\DotnetToolSettings.xml" />
    <file src="bin\Release\net8.0\publish\**" target="tools\net8.0\any" />
  </files>
</package>
